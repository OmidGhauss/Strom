NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# GEHEIM – darf NIEMALS als NEXT_PUBLIC_ benannt werden.
# Bypasses alle RLS-Regeln vollständig. Nur serverseitig in API Routes verwenden.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Rate Limiting (Upstash Redis) – optional in Dev, Pflicht in Produktion.
# Ohne diese Variablen ist Rate Limiting deaktiviert (Dev-Bypass).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile – optional in Dev, Pflicht in Produktion.
# Ohne TURNSTILE_SECRET_KEY wird Captcha-Verifikation übersprungen (Dev-Bypass).
# GEHEIM – darf NIEMALS als NEXT_PUBLIC_ benannt werden.
TURNSTILE_SECRET_KEY=

# Öffentlicher Site-Key – kein Geheimnis, darf NEXT_PUBLIC_ sein.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Demo/Dev-Token für Turnstile – NIEMALS in Produktion setzen.
# Cloudflare Testschlüssel (always-pass):
#   Site Key:    1x00000000000000000000AA
#   Secret Key:  1x0000000000000000000000000000000AA
#   Demo Token:  XXXX.DUMMY.TOKEN.XXXX
# Wenn gesetzt, wird dieser Token verwendet wenn kein Widget-Token vorhanden ist.
NEXT_PUBLIC_TURNSTILE_DEMO_TOKEN=

# E-Mail-Versand (Resend) – GEHEIM, niemals NEXT_PUBLIC_.
# RESEND_API_KEY: API-Key aus dem Resend-Dashboard.
# RESEND_FROM_EMAIL: verifizierte Absender-Adresse (z.B. angebote@firma.de).
# COMPANY_NAME: Firmenname für E-Mail-Kopfzeile und Signatur (kein Geheimnis).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
COMPANY_NAME=Ihr Energieberater
