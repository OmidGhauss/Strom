NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# GEHEIM – darf NIEMALS als NEXT_PUBLIC_ benannt werden.
# Bypasses alle RLS-Regeln vollständig. Nur serverseitig in API Routes verwenden.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Rate Limiting (Upstash Redis) – optional in Dev, Pflicht in Produktion.
# Ohne diese Variablen ist Rate Limiting deaktiviert (Dev-Bypass).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile – optional in Dev, Pflicht in Produktion.
# Ohne TURNSTILE_SECRET_KEY wird Captcha-Verifikation übersprungen (Dev-Bypass).
# GEHEIM – darf NIEMALS als NEXT_PUBLIC_ benannt werden.
TURNSTILE_SECRET_KEY=

# Öffentlicher Site-Key – kein Geheimnis, darf NEXT_PUBLIC_ sein.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
